{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    // @types/node so the shared crypto's Buffer fallback branch type-checks;
    // vitest for our own *.test.ts. DOM lib covers btoa/atob/WebCrypto.
    "types": ["node", "vitest/globals"],
    "baseUrl": ".",
    "paths": {
      "@shared/*": ["../desktop/src/shared/*"]
    }
  },
  "include": ["src"],
  // Only our own source is compiled from web/. The shared modules are pulled in
  // transitively via the @shared alias; the desktop's *.test.ts files are never
  // referenced by web source, so they are not type-checked here.
  "exclude": ["node_modules", "dist"]
}
